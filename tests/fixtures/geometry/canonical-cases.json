{
  "sharedContract": {
    "dot3": [
      {
        "id": "mixed-sign",
        "a": [1, 2, 3],
        "b": [4, -5, 6],
        "expected": 12
      }
    ],
    "cross3": [
      {
        "id": "basis-cross",
        "a": [1, 0, 0],
        "b": [0, 1, 0],
        "expected": [0, 0, 1]
      }
    ],
    "norm3": [
      {
        "id": "three-four-twelve",
        "v": [3, 4, 12],
        "expected": 13
      }
    ],
    "normalize3": [
      {
        "id": "axis-scale",
        "v": [0, 3, 4],
        "expected": [0, 0.6, 0.8]
      }
    ],
    "sliceNormalFromIOP": [
      {
        "id": "axial",
        "iop": [1, 0, 0, 0, 1, 0],
        "expected": [0, 0, 1]
      },
      {
        "id": "sagittal",
        "iop": [0, 1, 0, 0, 0, 1],
        "expected": [1, 0, 0]
      }
    ],
    "sliceAxisAlignmentFromSeries": [
      {
        "id": "aligned-axial",
        "series": {
          "orientation": [1, 0, 0, 0, 1, 0],
          "firstIPP": [0, 0, 0],
          "lastIPP": [0, 0, 9]
        },
        "expected": 1
      },
      {
        "id": "sheared-axial",
        "series": {
          "orientation": [1, 0, 0, 0, 1, 0],
          "firstIPP": [0, 0, 0],
          "lastIPP": [9, 0, 9]
        },
        "expected": 0.7071067811865475
      }
    ],
    "projectionAlongNormal": [
      {
        "id": "axial-z",
        "meta": {
          "ImagePositionPatient": [0, 0, 7]
        },
        "normal": [0, 0, 1],
        "expected": 7
      }
    ],
    "sortDatasetsSpatially": [
      {
        "id": "scrambled-axial-stack",
        "datasets": [
          {
            "InstanceNumber": 3,
            "ImageOrientationPatient": [1, 0, 0, 0, 1, 0],
            "ImagePositionPatient": [0, 0, 2]
          },
          {
            "InstanceNumber": 1,
            "ImageOrientationPatient": [1, 0, 0, 0, 1, 0],
            "ImagePositionPatient": [0, 0, 0]
          },
          {
            "InstanceNumber": 2,
            "ImageOrientationPatient": [1, 0, 0, 0, 1, 0],
            "ImagePositionPatient": [0, 0, 1]
          }
        ],
        "expectedInstanceOrder": [1, 2, 3]
      }
    ],
    "sliceSpacingStatsFromPositions": [
      {
        "id": "regular",
        "positions": [[0, 0, 0], [0, 0, 1], [0, 0, 2]],
        "normal": [0, 0, 1],
        "expected": { "mean": 1, "min": 1, "max": 1, "regular": true }
      },
      {
        "id": "irregular",
        "positions": [[0, 0, 0], [0, 0, 1], [0, 0, 3]],
        "normal": [0, 0, 1],
        "expected": { "mean": 1.5, "min": 1, "max": 2, "regular": false }
      },
      {
        "id": "duplicate-position",
        "positions": [[0, 0, 0], [0, 0, 0], [0, 0, 1]],
        "normal": [0, 0, 1],
        "expected": { "mean": 0.5, "min": 0, "max": 1, "regular": false }
      }
    ],
    "classifyGeometryKind": [
      {
        "id": "volume",
        "spacingStats": { "mean": 1, "regular": true },
        "sliceCount": 3,
        "expected": "cartesian_volume"
      },
      {
        "id": "irregular-stack",
        "spacingStats": { "mean": 1, "regular": false },
        "sliceCount": 3,
        "expected": "cartesian_stack_irregular"
      },
      {
        "id": "single-frame",
        "spacingStats": { "mean": 0, "regular": false },
        "sliceCount": 1,
        "expected": "single_frame"
      },
      {
        "id": "insufficient",
        "spacingStats": { "mean": 0, "regular": false },
        "sliceCount": 0,
        "expected": "insufficient"
      }
    ],
    "affineLpsFromSeries": [
      {
        "id": "axial-spacing",
        "series": {
          "pixelSpacing": [0.8, 0.7],
          "sliceSpacing": 1.5,
          "slices": 3,
          "firstIPP": [10, 20, 30],
          "lastIPP": [10, 20, 33],
          "orientation": [1, 0, 0, 0, 1, 0]
