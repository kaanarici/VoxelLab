{
  "name": "voxellab",
  "productName": "VoxelLab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main/index.js",
  "author": "VoxelLab contributors",
  "description": "VoxelLab: local-first research imaging viewer with browser and Electron desktop entrypoints.",
  "scripts": {
    "setup": "node scripts/setup_dev.mjs",
    "start": "node scripts/run_python.mjs python/serve.py",
    "build": "npm run render:config",
    "render:config": "node scripts/render_config.mjs",
    "desktop:start": "electron .",
    "desktop:package": "electron-forge package",
    "desktop:make": "electron-forge make",
    "desktop:make:mac": "electron-forge make --platform=darwin",
    "desktop:make:win": "electron-forge make --platform=win32",
    "desktop:smoke": "node --test tests/electron-runtime-smoke.mjs",
    "desktop:check": "node scripts/check_electron_desktop.mjs && node scripts/check_electron_package.mjs && node --test tests/electron-desktop-contract.test.mjs && npm run desktop:smoke",
    "lint": "eslint js electron viewer.js",
    "lint:ci": "eslint js electron viewer.js --max-warnings 0",
    "check": "npm run check:js && npm run check:py && npm run check:data && npm run check:geometry && npm run test:node && npm run test:browser",
    "check:js": "npm run lint:ci && npm run check:js:syntax && npm run check:styles && npm run desktop:check",
    "check:js:syntax": "node --check viewer.js && node --check middleware.js && for f in js/*.js electron/main/*.js electron/shared/*.js; do node --check \"$f\" || exit 1; done && node --check electron/preload/index.cjs",
    "check:styles": "node scripts/check_inline_styles.mjs",
    "check:py": "node scripts/run_python.mjs -m py_compile python/*.py scripts/*.py",
    "check:geometry": "node scripts/check_geometry_parity.mjs --js-only",
    "check:data": "node scripts/run_python.mjs scripts/check_manifest.py --manifest data/manifest.json --config config.json && node scripts/run_python.mjs scripts/check_assets.py --manifest data/manifest.json --mode local-fast",
    "check:data:full": "node scripts/run_python.mjs scripts/check_assets.py --manifest data/manifest.json --mode full",
    "check:cloud": "node scripts/run_python.mjs scripts/check_env.py --mode cloud --dry-run",
    "check:pipeline": "node scripts/run_python.mjs scripts/check_pipeline_ready.py",
    "ai:doctor": "node scripts/run_python.mjs scripts/check_ai_ready.py",
    "ai:refresh": "node scripts/run_python.mjs scripts/refresh_ai_data.py",
    "demo:install": "node scripts/run_python.mjs scripts/install_demo_data.py",
    "demo:verify:ome": "node scripts/verify_ome_microscopy_samples.mjs",
    "demo:verify:imagej": "node scripts/verify_imagej_microscopy_sample.mjs",
    "demo:verify:ome-zarr": "node scripts/verify_ome_zarr_public_sample.mjs",
    "demo:verify:microscopy": "node scripts/verify_microscopy_public_samples.mjs",
    "demo:build:lite": "node scripts/run_python.mjs scripts/build_openneuro_lite_pack.py",
    "modal:submit": "node scripts/run_python.mjs scripts/submit_modal_study.py",
    "test": "npm run test:node && npm run test:browser",
    "test:node": "node --test tests/*.test.mjs",
    "test:python": "node scripts/run_python.mjs -m pytest -q",
    "test:browser": "playwright test"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "electron": "^42.2.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0"
  },
  "dependencies": {
    "@cornerstonejs/codec-charls": "^1.2.3",
    "@cornerstonejs/codec-openjpeg": "^1.3.0",
    "dcmjs": "^0.33.0",
    "fzstd": "^0.1.1",
    "onnxruntime-web": "^1.17.3",
    "pako": "^2.1.0",
    "three": "^0.161.0"
  },
  "overrides": {
    "tar": "^7.5.15",
    "@inquirer/prompts": "7.10.1"
  },
  "config": {
    "forge": "./forge.config.cjs"
  }
}
